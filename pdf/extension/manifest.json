{
  "manifest_version": 3,
  "name": "Pdf Signing Agent",
  "version": "1.0.0",
  "description": "Sign documents with CAC/PIV smart cards directly in your browser",
  "browser_specific_settings": {
    "gecko": {
      "id": "pdf-signer@pick.haus",
      "strict_min_version": "109.0"
    }
  },
  "permissions": ["nativeMessaging", "storage"],
  "host_permissions": [
    "https://*.pdf.pick.haus/*",
    "https://*.pick.haus/*",
    "http://localhost:*/*",
    "http://127.0.0.1:*/*"
  ],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": [
        "https://*.pdf.pick.haus/*",
        "https://*.pick.haus/*",
        "http://localhost:*/*",
        "http://127.0.0.1:*/*"
      ],
      "js": ["content.js"],
      "run_at": "document_start"
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png"
    }
  },
  "web_accessible_resources": [
    {
      "resources": ["injected.js"],
      "matches": [
        "https://*.pdf.pick.haus/*",
        "https://*.pick.haus/*",
        "http://localhost:*/*",
        "http://127.0.0.1:*/*"
      ]
    }
  ]
}
